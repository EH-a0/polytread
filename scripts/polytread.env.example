# Copy to an operator-controlled location outside the repository and restrict permissions.
POLYTREAD_BIND=127.0.0.1:9878
POLYTREAD_DATA_DIR=./data
POLYTREAD_ALLOW_WEB_TRADING=false
POLYTREAD_LOG=info

# Trading is unavailable unless all four values are supplied.
PM_SIGNER_ADDRESS=
PM_FUNDER_ADDRESS=
PM_PRIVATE_KEY=
PM_SIGNATURE_TYPE=
